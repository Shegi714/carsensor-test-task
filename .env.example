DATABASE_URL="postgresql://cars_user:cars_pass@localhost:5432/cars_db?schema=public"
JWT_SECRET="super_secret_change_me"
API_PORT=4000
JWT_EXPIRES_IN="12h"

# Общая папка кеша фото (API раздаёт /uploads, воркер пишет сюда же). По умолчанию — <корень репозитория>/uploads
# UPLOADS_DIR=

# Воркер: повторы при скачивании фото и при скрапинге карточки (опционально)
# IMAGE_CACHE_PASSES=4
# REHYDRATE_SCRAPE_RETRIES=3
